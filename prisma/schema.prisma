// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}
datasource db {
  provider = "mysql"
}

//npx prisma db push para criar o banco de dados caso já não esteja criado

model Usuario {
  id        Int     @id @default(autoincrement())
  nome      String
  email     String  @unique
  senha     String

  id_perfil  Int     @unique
  perfil    Perfil  @relation(name: "UsuarioPerfil", fields: [id_perfil], references: [id])
}

model Perfil {
  id        Int      @id @default(autoincrement())
  perfil_nome String

  usuario   Usuario? @relation(name: "UsuarioPerfil")
}

//npx prisma migrate dev para fazer a migração e ligação do prisma; e também criar as tabelas;


